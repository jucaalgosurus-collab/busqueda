<!-- ============================== -->
<!-- SCRIPTS · INTERACTIVIDAD        -->
<!-- ============================== -->
<script>
(function() {
  const slides = document.querySelectorAll('.slide');
  const counter = document.getElementById('ct');
  const progress = document.getElementById('progress');
  const navDots = document.getElementById('navDots');

  // Build nav dots
  slides.forEach((s, i) => {
    const dot = document.createElement('button');
    dot.className = 'nav-dot';
    dot.setAttribute('aria-label', `Ir a slide ${i+1}`);
    dot.addEventListener('click', () => s.scrollIntoView({behavior: 'smooth'}));
    navDots.appendChild(dot);
  });

  // === Donut chart ===
  const segments = [
    {label: 'Cárnico',     val: 5, color: '#B08A52'},
    {label: 'Avícola',     val: 3, color: '#C9A36B'},
    {label: 'Bodega',      val: 3, color: '#7A5E38'},
    {label: 'Panadería',   val: 2, color: '#8A9A5B'},
    {label: 'Bebidas',     val: 1, color: '#6B8E5A'},
    {label: 'Supermercado',val: 1, color: '#C77B3A'},
    {label: 'Conservas',   val: 1, color: '#5C6170'},
    {label: 'Otros',       val: 1, color: '#3D414F'}
  ];
  const total = segments.reduce((a,b) => a+b.val, 0);
  const segG = document.getElementById('donut-segments');
  const legend = document.getElementById('donut-legend');
  const radius = 70;
  const circ = 2 * Math.PI * radius;
  let offset = 0;
  segments.forEach(seg => {
    const len = (seg.val / total) * circ;
    const c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    c.setAttribute('cx', '90');
    c.setAttribute('cy', '90');
    c.setAttribute('r', String(radius));
    c.setAttribute('fill', 'none');
    c.setAttribute('stroke', seg.color);
    c.setAttribute('stroke-width', '22');
    c.setAttribute('stroke-dasharray', `0 ${circ}`);
    c.style.transition = 'stroke-dasharray 1.4s cubic-bezier(0.16, 1, 0.3, 1)';
    segG.appendChild(c);
    // Legend
    const row = document.createElement('div');
    row.className = 'donut-legend-row';
    row.innerHTML = `<span class="swatch" style="background:${seg.color}"></span><span>${seg.label}</span><b>${seg.val}</b>`;
    legend.appendChild(row);
  });
  function animateDonut() {
    const donutSlide = document.querySelector('[data-slide="6"]');
    if (!donutSlide || !donutSlide.classList.contains('in')) return;
    let cum = 0;
    Array.from(segG.children).forEach((c, i) => {
      const len = (segments[i].val / total) * circ;
      c.setAttribute('stroke-dasharray', `${len} ${circ - len}`);
      c.setAttribute('stroke-dashoffset', String(-cum));
      cum += len;
    });
  }

  // === Reveal + counters on slide-in ===
  const revealObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        // Trigger all reveals inside this slide
        e.target.querySelectorAll('.reveal').forEach(r => r.classList.add('in'));
        // Trigger counters inside this slide
        e.target.querySelectorAll('[data-counter]').forEach(el => animateCounter(el));
        // Trigger bars inside this slide
        e.target.querySelectorAll('.tr-bar-fg').forEach(el => {
          const w = el.dataset.w;
          if (w) setTimeout(() => { el.style.width = w + '%'; }, 200);
        });
        // Trigger donut
        if (e.target.dataset.slide === '6') setTimeout(animateDonut, 300);
      }
    });
  }, { threshold: 0.3, rootMargin: '0px 0px -10% 0px' });
  slides.forEach(s => revealObs.observe(s));

  // FALLBACK: Si el observer no dispara (algunos browsers), forzar reveal tras 500ms
  setTimeout(() => {
    document.querySelectorAll('.reveal:not(.in)').forEach(el => el.classList.add('in'));
    document.querySelectorAll('.slide:not(.in)').forEach(el => el.classList.add('in'));
    // Animate bars
    document.querySelectorAll('.tr-bar-fg').forEach(el => {
      const w = el.dataset.w;
      if (w && el.style.width === '') el.style.width = w + '%';
    });
    // Animate counters
    document.querySelectorAll('[data-counter]').forEach(el => animateCounter(el));
    // Animate donut
    if (document.querySelector('[data-slide="6"]')) setTimeout(animateDonut, 300);
  }, 800);

  // SAFETY: Forzar visibilidad tras 2s pase lo que pase
  setTimeout(() => {
    document.querySelectorAll('.reveal, .slide').forEach(el => {
      el.style.opacity = '1';
      el.style.transform = 'none';
    });
  }, 2500);

  // === Counter animation ===
  function animateCounter(el) {
    if (el.dataset.animated) return;
    el.dataset.animated = '1';
    const target = parseFloat(el.dataset.counter);
    const prefix = el.dataset.prefix || '';
    const suffix = el.dataset.suffix || '';
    const duration = 1600;
    const start = performance.now();
    function tick(now) {
      const t = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - t, 4);
      const val = Math.round(target * eased);
      el.textContent = prefix + formatNumber(val) + suffix;
      if (t < 1) requestAnimationFrame(tick);
      else el.textContent = prefix + formatNumber(target) + suffix;
    }
    requestAnimationFrame(tick);
  }
  function formatNumber(n) {
    if (n >= 1000) return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    return String(n);
  }

  // === Slide counter + progress ===
  const counterObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const n = parseInt(e.target.dataset.slide);
        counter.textContent = String(n).padStart(2, '0');
        const pct = (n / slides.length) * 100;
        progress.style.width = pct + '%';
        document.querySelectorAll('.nav-dot').forEach((d, i) => {
          d.classList.toggle('active', i + 1 === n);
        });
      }
    });
  }, { threshold: 0.5 });
  slides.forEach(s => counterObs.observe(s));

  // === Map pin/list interaction ===
  const pins = document.querySelectorAll('.mapa-pin');
  const rows = document.querySelectorAll('.mapa-row');
  function highlight(prov) {
    pins.forEach(p => p.classList.toggle('active', p.dataset.prov === prov));
    rows.forEach(r => r.style.background = r.dataset.prov === prov ? 'var(--bg-elev-1)' : '');
  }
  pins.forEach(p => p.addEventListener('mouseenter', () => highlight(p.dataset.prov)));
  pins.forEach(p => p.addEventListener('mouseleave', () => {
    pins.forEach(x => x.classList.remove('active'));
    rows.forEach(r => r.style.background = '');
  }));
  rows.forEach(r => r.addEventListener('mouseenter', () => highlight(r.dataset.prov)));
  rows.forEach(r => r.addEventListener('mouseleave', () => {
    pins.forEach(x => x.classList.remove('active'));
    rows.forEach(r => r.style.background = '');
  }));

  // === Keyboard nav (Enter, Space, flechas, PageUp/Down, Home/End) ===
  function getCurrentIndex() {
    return Array.from(slides).findIndex(s => {
      const r = s.getBoundingClientRect();
      return r.top >= -100 && r.top < window.innerHeight/2;
    });
  }
  function goToSlide(n) {
    const target = Math.max(0, Math.min(slides.length - 1, n));
    if (slides[target]) slides[target].scrollIntoView({ behavior: 'smooth' });
  }

  document.addEventListener('keydown', (e) => {
    // Ignorar si el foco está en un input/textarea (defensivo)
    const tag = e.target.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA') return;

    const cur = getCurrentIndex();
    if (cur < 0) return;

    if (e.key === 'ArrowDown' || e.key === 'PageDown' || e.key === ' ' || e.key === 'Enter') {
      e.preventDefault();
      if (cur < slides.length - 1) goToSlide(cur + 1);
    }
    if (e.key === 'ArrowUp' || e.key === 'PageUp' || (e.key === 'Enter' && e.shiftKey)) {
      e.preventDefault();
      if (cur > 0) goToSlide(cur - 1);
    }
    if (e.key === 'ArrowRight') { e.preventDefault(); goToSlide(cur + 1); }
    if (e.key === 'ArrowLeft')  { e.preventDefault(); goToSlide(cur - 1); }
    if (e.key === 'Home') { e.preventDefault(); goToSlide(0); }
    if (e.key === 'End')  { e.preventDefault(); goToSlide(slides.length - 1); }
  });

  // === Botones de navegación visibles (click) ===
  const btnPrev = document.getElementById('navPrev');
  const btnNext = document.getElementById('navNext');
  function updateBtnState() {
    const cur = getCurrentIndex();
    if (btnPrev) btnPrev.classList.toggle('is-disabled', cur <= 0);
    if (btnNext) btnNext.classList.toggle('is-disabled', cur >= slides.length - 1 || cur < 0);
  }
  if (btnPrev) btnPrev.addEventListener('click', () => { const c = getCurrentIndex(); if (c > 0) goToSlide(c - 1); });
  if (btnNext) btnNext.addEventListener('click', () => { const c = getCurrentIndex(); if (c < slides.length - 1) goToSlide(c + 1); });
  // Actualizar estado disabled al cambiar de slide
  document.addEventListener('scroll', () => {
    if (window._navBtnRaf) return;
    window._navBtnRaf = requestAnimationFrame(() => {
      updateBtnState();
      window._navBtnRaf = null;
    });
  }, { passive: true });
  updateBtnState();
})();
</script>

</body>
</html>
