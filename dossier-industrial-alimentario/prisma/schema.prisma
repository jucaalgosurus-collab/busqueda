// HERMES-DOSSIER v6 — Esquema de Base de Datos
// Producto: Dossier Industrial Alimentario (A&B OSINT) — Réplica legacy 1:1
// Detecta SOLO desimplantaciones de grandes empresas A&B en España.
// 2026-06-02 — Sprint 6 (Re-arquitectura v6)

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 1. COMPANY — Empresa con KPIs (réplica legacy 1:1)
// ============================================================================
model Company {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  cif           String?  @unique
  sector        String   // Industria (sprint E.3, 10 sectores del brief 2026-06-04). Ver lib/industria.ts:IndustriaSector. Ejemplos: 'Alimentos y Bebidas' | 'Construccion' | 'Vehiculos' | 'Maquinaria' | 'Stock industrial' | 'Equipamiento Medico Laboratorio Biotecnologia' | 'Propiedad Intelectual Marcas y Patentes' | 'Energia' | 'Patentes' | 'Industria en General'
  subsector     String   // 'Pescado congelado', 'Lácteos', 'Cerveza', 'Azúcar', 'Refino de petróleo', etc.
  cnae          String?  // '10.2', '10.5', '11.0', '21.1', '35.1', etc.
  parentGroup   String?  // 'AB Foods', 'Grupo Damm', 'Nestlé S.A.', etc.
  hqCity        String?
  hqRegion      String?
  website       String?
  logoUrl       String?
  heroImageUrl  String?

  // KPIs globales (réplica legacy)
  facturacionM     Float?
  facturacionYear  Int?
  ebitdaM          Float?
  beneficioNetoM   Float?
  deudaNetaM       Float?
  empleadosTotal   Int?

  tier          String   @default("A") // 'A' | 'B'
  status        String   @default("active") // 'active' | 'inactive'
  priority      Int      @default(0)
  // Sprint CRM.1 — Pipeline comercial Surus (5 etapas). Null = sin clasificar.
  pipelineStage String?  // 'nuevo' | 'cualificado' | 'propuesta' | 'negociacion' | 'cerrado'

  plants        Plant[]
  sources       Source[]
  operations    Operation[]
  financials    Financial[]
  notes         Note[]
  documents     Document[]
  auctionChecks AuctionCheck[]
  plantContacts PlantContact[]
  outreachLogs  OutreachLog[]
  bormeEvents   BormeEvent[]
  patents       Patent[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastScannedAt DateTime?

  @@index([sector, subsector])
  @@index([tier, status])
}

// ============================================================================
// 2. PLANT — Planta con ubicación + estado + especialidad
// ============================================================================
model Plant {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name          String   // 'Alovera', 'Aldaia', 'Gurb', 'Sabón', 'Morás', 'La Bañeza', 'Miranda de Ebro', etc.
  ccaa          String   // 'Galicia', 'Madrid', 'Cataluña', 'Andalucía', etc.
  province      String?
  city          String?
  address       String?
  lat           Float?
  lng           Float?

  status        String   // 'operativa' | 'en_inversion' | 'en_desmantelamiento' | 'cerrada' | 'vendida' | 'en_proyecto' | 'en_conversion' | 'en_venta'
  specialty     String?  // 'Leche UHT', 'Agua mineral', 'Azúcar de remolacha', 'Cerveza', 'Pescado congelado'
  employees     Int?
  parcelaM2     Float?
  naveM2        Float?

  // E.10 — Lifecycle explícito de la sede. openedAt se rellena al crear
  // manualmente o al confirmar detección; closedAt se rellena al cerrar
  // o vender. Permiten queries tipo "sedes abiertas en 2024".
  openedAt      DateTime?
  closedAt      DateTime?

  closureYear   Int?
  investmentMEur Float?
  notes         String?

  // B.8 — Stale detection (planta sin novedad en 21d)
  isStale       Boolean   @default(false)
  staleReason   String?   // 'sin_novedad_21d' | 'cerrada_registrada' | 'estado_terminal' | 'planta_recien_creada' | null
  staleAt       DateTime? // última vez que se marcó stale
  staleCheckedAt DateTime? // última vez que se evaluó

  inventory     TechnicalInventory[]
  contacts      PlantContact[]
  events        TimelineEvent[]
  documents     Document[]
  operations    Operation[]
  sources       Source[]  // QW-10: noticias asociadas a esta sede

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, name])
  @@index([status])
  @@index([ccaa])
  @@index([isStale])
  @@index([staleCheckedAt])
}

// ============================================================================
// 3. PLANT_CONTACT — Contacto ASIGNADO A PLANTA concreta (clave: persona + instalación)
// ============================================================================
model PlantContact {
  id            String   @id @default(uuid())
  plantId       String
  plant         Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fullName      String
  role          String   // 'Director de Planta', 'Director de Operaciones', 'CEO', 'Plant Manager', etc.
  roleCategory  String?  // 'plant_manager' | 'coo' | 'cfo' | 'ceo' | 'procurement' | 'sustainability' | 'maintenance' | 'ere_responsible' | 'other'

  // Datos de contacto (enriquecidos)
  linkedinUrl   String?
  email         String?
  emailVerified Boolean  @default(false)
  hunterId      String?
  phone         String?

  // Origen y confianza
  sourceUrl     String?  // URL donde se encontró la persona
  sourceOutlet  String?  // 'LinkedIn', 'El País', 'Hunter.io', 'El Periódico'
  via           String?  // 'google_cse' | 'playwright' — método de captura (Plan B 2026-06-03)
  confidence    Float    @default(0.5)
  lastEnrichedAt DateTime?
  notes         String?

  outreachLogs  OutreachLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([plantId])
  @@index([companyId, roleCategory])
  @@index([linkedinUrl])
  @@index([emailVerified])
}

// ============================================================================
// 4. TECHNICAL_INVENTORY — Inventario técnico con brand + model + specs
// ============================================================================
model TechnicalInventory {
  id            String   @id @default(uuid())
  plantId       String
  plant         Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  category      String   // 'linea_produccion' | 'caldera' | 'sistema_almacenaje' | 'envasado' | 'refrigeracion' | 'logistica' | 'co_generacion' | 'packaging' | 'molino' | 'horno' | 'edificio' | 'parcela'
  brand         String?  // 'GEA', 'WEG', 'Krones', 'Linde', 'Magnon/Ence', 'HoloLens', etc.
  model         String?  // 'MSA 90-01-076', 'Dynamics 365', 'Frame 5'
  specs         String?  // '2 calderas 10 MWt', '70 Tm/día', '85K → 120K t/año'
  quantity      Int?
  status        String   // 'operativo' | 'a_sustituir' | 'liberado' | 'desmantelado' | 'vendido' | 'en_uso' | 'en_obra'

  releaseWindow String?  // 'Q2 2026', '2027', '2do sem 2026'
  estimatedValueEur Float?
  source        String?
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([plantId, status])
  @@index([category, brand])
}

// ============================================================================
// 5. OPERATION — Operación de desimplantación / inversión / ERE
// ============================================================================
model Operation {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plantId       String?
  plant         Plant?   @relation(fields: [plantId], references: [id])

  type          String   // 'plant_closure' | 'line_closure' | 'ERE' | 'plant_sale' | 'relocation' | 'investment' | 'divestment' | 'biomass_plant' | 'warehouse' | 'decommissioning' | 'acquisition' | 'concurso_acreedores' | 'subasta'
  title         String
  description   String?  @db.Text
  amountMeur    Float?
  jobsAffected  Int?
  announcedAt   DateTime
  status        String   @default("announced") // 'announced' | 'in_negotiation' | 'in_execution' | 'executed' | 'cancelled' | 'in_scope' | 'out_of_scope'
  confidence    Float    @default(0.7)
  sourceUrl     String?
  sourceOutlet  String?

  events        TimelineEvent[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, type])
  @@index([plantId])
  @@index([announcedAt])
  @@index([status])
}

// ============================================================================
// 6. TIMELINE_EVENT — Eventos cronológicos datados
// ============================================================================
model TimelineEvent {
  id            String   @id @default(uuid())
  plantId       String?
  plant         Plant?   @relation(fields: [plantId], references: [id])
  operationId   String?
  operation     Operation? @relation(fields: [operationId], references: [id])
  companyId     String

  date          DateTime
  title         String
  description   String?
  impact        String?
  sourceUrl     String?
  sourceOutlet  String?

  createdAt     DateTime @default(now())

  @@index([companyId, date])
  @@index([plantId, date])
  @@index([date])
}

// ============================================================================
// 7. FINANCIAL — Datos financieros: inversiones, desinversiones, KPIs
// ============================================================================
model Financial {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  year          Int
  concept       String   // 'Almacén automatizado Alovera', 'Planta biomasa', 'Modernización 2022', 'Ampliación capital 283M€'
  amountMeur    Float
  category      String?  // 'investment' | 'divestment' | 'capital_increase' | 'debt_restructuring' | 'impairment' | 'revenue' | 'ebitda'
  plantId       String?
  sourceUrl     String?
  notes         String?

  createdAt     DateTime @default(now())

  @@index([companyId, year])
  @@index([category])
}

// ============================================================================
// 8. SOURCE — Fuentes scrapeadas (URLs clickeables)
// ============================================================================
model Source {
  id            String   @id @default(uuid())
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id])

  // QW-10: noticia → planta (sede) — null si la noticia no se asocia a una sede concreta
  plantId       String?
  plant         Plant?   @relation(fields: [plantId], references: [id], onDelete: SetNull)

  url           String   @unique
  title         String
  outlet        String
  outletType    String   // 'corporate_newsroom' | 'nacional' | 'regional' | 'local' | 'sector' | 'bofficial' | 'syndicate' | 'linkedin'
  language      String   @default("es")
  publishedAt   DateTime?
  scrapedAt     DateTime @default(now())
  contentHash   String?

  // E.3: sector transversal (vía outletType) o por CNAE de companyId. Se computa
  // en E.3b backfill y al ingestar nuevas sources.
  sector        String?

  // Filtro desimplantación
  deimplantationSignal Boolean @default(false)
  outOfScopeReason     String?
  isStale              Boolean @default(false)

  contentText   String?  @db.Text
  contentTsv    Unsupported("tsvector")?

  @@index([companyId, publishedAt])
  @@index([plantId])
  @@index([outletType])
  @@index([deimplantationSignal])
  @@index([isStale])
  @@index([publishedAt])
  @@index([sector])
}

// ============================================================================
// 8b. MATCH_REVIEW — Cola de revisión de match heurístico Source → Company
//     Sprint 1 (2026-06-05): cuando matchFuzzy devuelve score 0.70-0.85,
//     se inserta aquí para que un humano decida linkear/dismissal/crear.
// ============================================================================
model MatchReview {
  id             String   @id @default(cuid())
  sourceId       String   @unique
  title          String
  topCandidates  Json     // [{companyId, name, score, method}, ...] top 5
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?
  resolvedBy     String?
  decision       String?  // 'linked' | 'dismissed' | 'new_company'

  @@index([resolvedAt])
}

// ============================================================================
// 9. AUCTION_CHECK — Verificación de subastas por plataforma
// ============================================================================
model AuctionCheck {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName   String
  platform      String   // 'Escrapalia', 'Surplex', 'Troostwijk', 'GUTINVEST', 'HGP', 'Apex', 'CFT', 'Industrial Auctions', 'Machineryline'
  result        String   // 'sin_activos' | 'activos_detectados' | 'historial' | 'no_verificado'
  details       String?
  checkedAt     DateTime @default(now())

  @@index([companyId, platform])
  @@index([checkedAt])
}

// ============================================================================
// 10. DOCUMENT — PDFs (EINF) e imágenes (logo, hero, planta)
// ============================================================================
model Document {
  id            String   @id @default(uuid())
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plantId       String?
  plant         Plant?   @relation(fields: [plantId], references: [id], onDelete: Cascade)

  kind          String   // 'pdf' | 'logo' | 'hero' | 'plant_photo' | 'nameplate' | 'certificate' | 'balance_sheet' | 'photo' | 'press_release'
  fileUrl       String
  fileName      String
  fileSize      Int?
  mimeType      String?
  externalUrl   String?  // Para documentos remotos (ej. EINF en nueva-pescanova.com)

  // Para MOCR
  ocrText       String?  @db.Text
  ocrProvider   String?  // 'gemini' | 'docling'
  ocrConfidence Float?
  ocrEvaluatedAt DateTime?

  uploadedAt    DateTime @default(now())
  uploadedBy    String?  @default("anon")

  evaluations   SkillEvaluation[]

  @@index([companyId, kind])
  @@index([plantId, kind])
}

// ============================================================================
// 11. NOTE — Notas editables (sin auth)
// ============================================================================
model Note {
  id            String   @id @default(uuid())
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plantId       String?
  contactId     String?
  operationId   String?

  body          String   @db.Text
  author        String   @default("anonimo")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([plantId])
}

// ============================================================================
// 12. SCAN_CONFIG — Configuración cadencia 2-tier
// ============================================================================
model ScanConfig {
  id            String   @id @default(uuid())
  agentName     String   @unique
  cadenceDays   Int      @default(2)
  firstRunBackfillDays Int  @default(15)
  lastRunAt     DateTime?
  lastBackfillAt DateTime?
  isFirstRun    Boolean  @default(true)
  isActive      Boolean  @default(true)
  queryConfig   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================================
// 13. SEARCH_RUN — Log de runs
// ============================================================================
model SearchRun {
  id            String   @id @default(uuid())
  agentName     String
  query         Json?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  itemsFound    Int      @default(0)
  itemsNew      Int      @default(0)
  itemsUpdated  Int      @default(0)
  itemsInScope  Int      @default(0)
  itemsOutOfScope Int    @default(0)
  errorsCount   Int      @default(0)
  costEur       Float    @default(0)
  mode          String?  // 'backfill_15d' | 'incremental_2d'

  @@index([agentName, startedAt])
}

// ============================================================================
// 14. SKILL_EVALUATION — MOCR results
// ============================================================================
model SkillEvaluation {
  id              String   @id @default(uuid())
  documentId      String
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  skill           String   // 'hermes-asset-valuation' | 'hermes-certifications' | 'hermes-technical-audit'
  grade           String?  // 'A' | 'B' | 'C' | 'D'
  score           Int?
  findings        Json?
  evaluatedAt     DateTime @default(now())
  evaluatorVersion String?

  @@index([documentId])
  @@index([skill, grade])
}

// ============================================================================
// 15. OUTREACH_LOG — Audit log de generación de borradores outreach (QW-9)
// ============================================================================
model OutreachLog {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId   String
  contact     PlantContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  channel     String   // 'email' | 'linkedin_dm_short' | 'linkedin_dm_long' | 'preview_only'
  subject     String
  body        String   @db.Text
  status      String   @default("generated") // 'generated' | 'copied' | 'sent_external' | 'discarded'
  hash        String   // SHA-256(body) para trazabilidad
  seed        Int      // seed determinista usado para DeepSeek
  model       String   @default("deepseek-chat")
  painPointCount Int  @default(0)
  wordCount   Int      @default(0)

  createdAt   DateTime @default(now())
  createdBy   String   @default("anon")

  @@index([companyId, createdAt])
  @@index([contactId, channel])
  @@index([status])
}

// ============================================================================
// 16. BORME_EVENT — Eventos BORME histórico 365d para enriquecer Company (Sprint C.1)
// ============================================================================
model BormeEvent {
  id            String   @id @default(uuid())
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  matchHash     String   @unique // sha256(cif+tipo+fecha+bormeId) para idempotencia
  cif           String?  // CIF normalizado (sin guiones/espacios, mayúsculas)
  companyName   String   // nombre tal como aparece en BORME
  fecha         DateTime // fecha publicación BORME
  tipo          String   // 'constitucion'|'cambio_domicilio'|'ampliacion_capital'|'reduccion_capital'|'escision'|'cuentas'|'consejo'|'disolucion'|'nombramiento'|'cese'|'reeleccion'|'transformacion'|'fusion_absorcion'|'modificacion_estatutos'|'extincion'|'declaracion_concurso'
  bormeId       String   // ej: 'BORME-A-2026-45-12'
  provincia     String   // 'ALBACETE', 'MADRID', etc.
  domicilio     String?  // domicilio social si aparece
  capital       String?  // capital social si aparece
  rawText       String   @db.Text // texto completo del acto
  fuente        String   // URL al BORME original
  matchedAt     DateTime @default(now())

  @@index([companyId])
  @@index([cif])
  @@index([fecha])
  @@index([tipo])
  @@index([companyName])
}

// ============================================================================
// 17. PATENT — Patentes / modelos de utilidad del titular (Sprint C.3)
// Patentes y modelos de utilidad de la OEPM (España) y, opcionalmente,
// familia internacional vía EPO OPS. Enriquecimiento de cartera IP — no
// es señal de desimplantación. Empresa con cartera viva = I+D activa.
// ============================================================================
model Patent {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  matchHash         String   @unique // sha256(companyId+pubNumber+titleLower)[:32]

  publicationNumber String   // 'ES1234567A1', 'ES1234567B2', 'EP3456789B1', 'U202400001'
  title             String   @db.Text
  applicant         String?  // 'PASCUAL, S.A.U.' o 'GRUPO DAMM, S.L.'
  inventors         String?  // nombres separados por coma

  filingDate        DateTime? // fecha de solicitud
  publicationDate   DateTime? // fecha de publicación
  grantDate         DateTime? // fecha de concesión (null si pending/expired)

  legalStatus       String   // 'granted' | 'pending' | 'expired' | 'withdrawn' | 'unknown'
  cnae              String?  // clasificación CIP si aparece (ej. 'A23L 1/00')
  source            String   // 'OEPM Invenes' | 'EPO OPS'
  sourceUrl         String   // URL al detalle OEPM
  language          String   @default("es")

  scrapedAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([companyId, publicationDate])
  @@index([legalStatus])
  @@index([filingDate])
}

// ============================================================================
// 18. EMAIL_VERIFICATION — Cache de verificación Hunter.io (Sprint D.1.6)
// Regla 10208: "Si una sede/contacto YA está verificado, NO lo tienes que
// volver a comprobar ni buscar." Cada verificación Hunter cuesta 1 crédito;
// este cache evita re-verificar emails ya confirmados durante 30 días.
// Hunter puede devolver status='unknown' (catch-all / sin info) — también
// se cachea 30d para no martillear la API. Rate limit (429) NO se persiste.
// ============================================================================
model EmailVerification {
  id          String   @id @default(cuid())
  email       String   @unique
  status      String   // 'valid' | 'invalid' | 'accept_all' | 'unknown' | 'disposable' | 'webmail' | 'error'
  score       Int?     // 0-100 (Hunter score)
  verifiedAt  DateTime @default(now())
  expiresAt   DateTime // default = verifiedAt + 30d
  raw         Json?    // respuesta completa de Hunter por si auditoría

  @@index([email])
  @@index([expiresAt])
}

// ============================================================================
// 19. USER — Usuarios del panel admin (E.10)
// jucaalgo es el admin por defecto. Los usuarios 'user' solo pueden cambiar
// su contraseña; los 'admin' pueden CRUD usuarios + CRUD empresas + CRUD
// sedes. Hash de password con scrypt (Node built-in, sin dependencias).
// ============================================================================
model User {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  role          String   @default("user") // 'admin' | 'user'
  displayName   String?
  isActive      Boolean  @default(true)
  mustChangePassword Boolean @default(false)

  lastLoginAt   DateTime?
  lastLoginIp   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?  // username del admin que lo creó

  sessions      SessionLog[]

  @@index([role, isActive])
}

// ============================================================================
// 20. SESSION_LOG — Audit de conexiones (E.10 dashboard "quién se conecta")
// Cada login (vía /api/auth/login) registra un row con IP, UA, loginAt.
// El logout (vía /api/auth/logout) actualiza logoutAt y durationSec.
// Track de "tiempo conectado" + "desde qué IP" para el panel admin.
// ============================================================================
model SessionLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  username    String   // snapshot por si el user se borra después
  loginAt     DateTime @default(now())
  logoutAt    DateTime?
  durationSec Int?

  ip          String?  // X-Forwarded-For o remote_addr
  userAgent   String?  // User-Agent
  country     String?  // futuro: GeoIP

  @@index([userId, loginAt])
  @@index([username, loginAt])
  @@index([ip])
}
