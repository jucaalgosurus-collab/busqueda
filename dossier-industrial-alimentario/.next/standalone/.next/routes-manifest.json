{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "/dossier",
  "redirects": [
    {
      "source": "/dossier/",
      "destination": "/dossier",
      "basePath": false,
      "internal": true,
      "statusCode": 308,
      "regex": "^/dossier/$"
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/empresas/[slug]",
      "regex": "^/api/empresas/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/empresas/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/empresas/[slug]/notes",
      "regex": "^/api/empresas/([^/]+?)/notes(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/empresas/(?<nxtPslug>[^/]+?)/notes(?:/)?$"
    },
    {
      "page": "/api/empresas/[slug]/upload",
      "regex": "^/api/empresas/([^/]+?)/upload(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/empresas/(?<nxtPslug>[^/]+?)/upload(?:/)?$"
    },
    {
      "page": "/empresas/[slug]",
      "regex": "^/empresas/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/empresas/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/agentes",
      "regex": "^/agentes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/agentes(?:/)?$"
    },
    {
      "page": "/contactos",
      "regex": "^/contactos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contactos(?:/)?$"
    },
    {
      "page": "/empresas",
      "regex": "^/empresas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/empresas(?:/)?$"
    },
    {
      "page": "/eventos",
      "regex": "^/eventos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/eventos(?:/)?$"
    },
    {
      "page": "/hallazgos",
      "regex": "^/hallazgos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/hallazgos(?:/)?$"
    },
    {
      "page": "/legacy",
      "regex": "^/legacy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/legacy(?:/)?$"
    },
    {
      "page": "/mocr",
      "regex": "^/mocr(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/mocr(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}