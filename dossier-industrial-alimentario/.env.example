# HERMES-DOSSIER — Environment variables (TEMPLATE)
# Copy to .env and fill in real values. .env is gitignored, this is not.

# --- Database ---
# Local PostgreSQL 18 (Ubuntu 26.04 default)
DATABASE_URL=postgresql://surus:CHANGE_ME@127.0.0.1:5432/hermes_dossier?schema=public

# --- Next.js ---
NEXT_PUBLIC_BASE_PATH=/dossier
NEXT_PUBLIC_API_BASE=/dossier/api
PORT=3002
HOSTNAME=127.0.0.1
NODE_ENV=production

# --- External APIs (Free tier) ---
# Gemini 2.5 Vision — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Hunter.io — https://hunter.io/api (25 verif/month free)
HUNTER_API_KEY=your_hunter_api_key_here
# Google Custom Search (LinkedIn search) — https://programmablesearchengine.google.com
# Crear buscador limitado a linkedin.com/in/*, luego obtener API key en Google Cloud Console
GOOGLE_CSE_KEY=your_google_cse_api_key_here
GOOGLE_CSE_CX=your_google_cse_cx_id_here
# DeepSeek — https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MOCK=0
# OpenAI (fallback) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Telegram notifications ---
# Bot token from @BotFather, chat id from getUpdates after /start
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Admin bootstrap (E.10) ---
# Used only by scripts/seed-admin.ts. Must be set even in production
# for first-time admin user creation, then can be unset.
ADMIN_USERNAME=admin
ADMIN_SEED_PASSWORD=CHANGE_ME_on_first_run

# --- Meta ---
HERMES_DOSSIER_VERSION=0.1.0
